# AURA BANK - SMTP Email OTP Configuration Example
# Salin file ini menjadi .env dan isi nilai yang sesuai.

# Server SMTP (Gunakan smtp.gmail.com untuk Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Alamat email pengirim (Gmail Anda)
SENDER_EMAIL=your_email@gmail.com

# Sandi Aplikasi Google (16 karakter tanpa spasi dari setelan Google Account Security)
# Petunjuk pembuatan: https://myaccount.google.com/security -> Sandi Aplikasi (App Passwords)
SENDER_PASSWORD=your_app_password_here
